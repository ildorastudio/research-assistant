# OpenRouter API key. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-replace-me

# Single model used to clarify and rewrite the prompt. Strong reasoning model recommended.
IMPROVER_MODEL=anthropic/claude-sonnet-4.6

# Comma-separated OpenRouter slugs, in your preference order (trust ranking).
# The reviewer uses this order as a tiebreaker when models disagree.
# Tune research depth by adding or removing models.
RESEARCHER_MODELS=anthropic/claude-opus-4,anthropic/claude-sonnet-4,openai/gpt-4o,google/gemini-pro-1.5,deepseek/deepseek-chat

# Single model used to synthesize researcher outputs. Strong reasoning model recommended.
# Safe to set to the same slug as IMPROVER_MODEL.
REVIEWER_MODEL=anthropic/claude-opus-4

# Per-call HTTP timeout, in seconds.
REQUEST_TIMEOUT_SECONDS=180

# Number of retries AFTER the first attempt (so MAX_RETRIES=2 means up to 3 total calls).
MAX_RETRIES=1

# Pipeline aborts if fewer than this many researchers return a usable response.
MIN_SUCCESSFUL_RESEARCHERS=2
